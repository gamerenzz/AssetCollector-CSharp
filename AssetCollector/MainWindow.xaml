<Window x:Class="AssetCollector.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="终端资产管理平台-客户端 v2.0" Height="650" Width="950"
        WindowStartupLocation="CenterScreen" Background="#F5F5F5" FontFamily="Microsoft YaHei"
        Closing="Window_Closing"> <!-- 绑定关闭事件，用于记忆窗口尺寸 -->
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- 顶部工具栏（帮助） -->
            <RowDefinition Height="Auto"/> <!-- 服务器配置 -->
            <RowDefinition Height="Auto"/> <!-- 位置信息 -->
            <RowDefinition Height="Auto"/> <!-- 操作按钮 -->
            <RowDefinition Height="*"/>    <!-- 数据表格 -->
            <RowDefinition Height="Auto"/> <!-- 底部进度条 -->
        </Grid.RowDefinitions>

        <!-- 0. 顶部工具栏 -->
        <DockPanel Grid.Row="0" Margin="0,0,0,5">
            <TextBlock Text="终端资产管理" FontSize="16" FontWeight="Bold" Foreground="#333333" VerticalAlignment="Center"/>
            <Button Content="帮助 / 关于" Width="90" Height="25" HorizontalAlignment="Right" Click="BtnHelp_Click" Background="#E1E1E1" BorderThickness="0"/>
        </DockPanel>

        <!-- 1. 服务器配置 -->
        <GroupBox Grid.Row="1" Header="服务器配置" Margin="0,0,0,10" Padding="10,5">
            <StackPanel Orientation="Horizontal">
                <Label Content="服务器地址:" FontWeight="Bold" VerticalAlignment="Center"/>
                <TextBox x:Name="TxtServerUrl" Text="https://localhost:51710" Width="300" Margin="10,0,0,0" TextChanged="Input_TextChanged" VerticalContentAlignment="Center"/>
            </StackPanel>
        </GroupBox>

        <!-- 2. 位置信息 -->
        <GroupBox Grid.Row="2" Header="位置信息" Margin="0,0,0,10" Padding="10,10">
            <StackPanel>
                <!-- 标准字段 -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                    <Label Content="楼号:" Width="60" VerticalAlignment="Center"/>
                    <TextBox x:Name="TxtBuilding" Width="120" TextChanged="Input_TextChanged" VerticalContentAlignment="Center"/>
                    <Label Content="楼层:" Width="60" Margin="15,0,0,0" VerticalAlignment="Center"/>
                    <TextBox x:Name="TxtFloor" Width="120" TextChanged="Input_TextChanged" VerticalContentAlignment="Center"/>
                    <Label Content="科室:" Width="60" Margin="15,0,0,0" VerticalAlignment="Center"/>
                    <TextBox x:Name="TxtDept" Width="120" TextChanged="Input_TextChanged" VerticalContentAlignment="Center"/>
                    <Label Content="资产类型:" Width="65" Margin="15,0,0,0" VerticalAlignment="Center"/>
                    <TextBox x:Name="TxtAssetType" Text="计算机" Width="120" TextChanged="Input_TextChanged" VerticalContentAlignment="Center"/>
                </StackPanel>

                <!-- 【新增】动态自定义字段容器，支持换行 -->
                <WrapPanel x:Name="CustomFieldsContainer" Orientation="Horizontal" Margin="0,5,0,5"/>

                <!-- 操作：新增自定义字段 -->
                <Button x:Name="BtnAddField" Content="+ 新增自定义字段" Width="130" Height="25" HorizontalAlignment="Left" Margin="5,5,0,0" Click="BtnAddField_Click" Background="#E1E1E1" BorderThickness="0"/>
            </StackPanel>
        </GroupBox>

        <!-- 3. 操作按钮 -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,5,0,10">
            <Button x:Name="BtnScan" Content="扫描硬件信息" Width="140" Height="35" Margin="0,0,20,0" Click="BtnScan_Click" Background="#0078D7" Foreground="White" BorderThickness="0" IsEnabled="False"/>
            <Button x:Name="BtnUpload" Content="上传至服务器" Width="140" Height="35" Margin="0,0,20,0" Click="BtnUpload_Click" IsEnabled="False"/>
            <Button x:Name="BtnExport" Content="导出数据 (Excel)" Width="140" Height="35" Click="BtnExport_Click" IsEnabled="False"/>
        </StackPanel>

        <!-- 4. 采集结果表格 -->
        <GroupBox Grid.Row="4" Header="采集结果" Margin="0,0,0,10">
            <DataGrid x:Name="GridResults" AutoGenerateColumns="False" IsReadOnly="True" HeadersVisibility="Column" GridLinesVisibility="Horizontal" AlternatingRowBackground="#F9F9F9">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="项目" Binding="{Binding Key}" Width="150" FontWeight="Bold"/>
                    <DataGridTextColumn Header="内容" Binding="{Binding Value}" Width="*">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="TextWrapping" Value="Wrap"/> <!-- 允许单元格内文字自动换行（对展示长软件列表非常有用） -->
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                </DataGrid.Columns>
            </DataGrid>
        </GroupBox>

        <!-- 5. 底部进度状态 -->
        <Grid Grid.Row="5" Margin="0,5,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="TxtStatus" Grid.Column="0" Text="准备就绪" VerticalAlignment="Center" Foreground="#666666" Margin="0,0,10,0"/>
            <ProgressBar x:Name="ProgBar" Grid.Column="1" Height="15" Minimum="0" Maximum="100" Value="0" Visibility="Hidden"/>
        </Grid>
    </Grid>
</Window>
